# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Expense Tracker
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# localStorage keys used when the user is NOT signed in (guest mode).
NEXT_PUBLIC_APP_LOCAL_STORAGE_TRANSACTIONS_KEY=expense_tracker_transactions
NEXT_PUBLIC_APP_LOCAL_STORAGE_RECURRING_KEY=expense_tracker_recurring
NEXT_PUBLIC_APP_LOCAL_STORAGE_WALLETS_KEY=expense-tracker-wallets
NEXT_PUBLIC_APP_LOCAL_STORAGE_AUTOSAVE_KEY=expense_tracker_autosave

# ── Firebase Client SDK (public — safe to expose in the browser) ────────────
# Copy these from Firebase Console → Project settings → Your apps → Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=asia-southeast1

# ── Firebase App Check (optional) ───────────────────────────────────────────
# A reCAPTCHA v3 site key from Firebase Console → App Check → Apps.
# Leave empty to disable App Check (init becomes a no-op).
NEXT_PUBLIC_FIREBASE_APP_CHECK_RECAPTCHA_KEY=

# App Check debug token for local development:
#   `true`  — SDK prints a fresh token to the console each session; register it
#             in Firebase Console → App Check → Apps → Manage debug tokens.
#   <token> — paste a previously-registered token for stability across restarts.
# Leave empty in production.
NEXT_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=
